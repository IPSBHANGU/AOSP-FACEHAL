on post-fs-data
    mkdir /data/vendor/biometrics 0770 system system
    mkdir /data/vendor/biometrics/face 0770 system system

service vendor.face-hal /vendor/bin/hw/android.hardware.biometrics.face-service.milahaina
    class hal
    user system
    group system camera input
    capabilities SYS_NICE
    task_profiles CameraServicePerformance MaxPerformance
    interface aidl android.hardware.biometrics.face.IFace/default
    interface aidl vendor.milahaina.biometrics.face.IVisionService/default
